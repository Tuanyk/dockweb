# Website source code (managed separately with their own git repos)
sites/*/
!sites/*/.dockweb.conf

# Environment (contains passwords)
.env

# Auto-generated (regenerated by dockweb on start)
docker-compose.sites.yml
nginx/conf.d/*.conf
!nginx/conf.d/00-default.conf

# Runtime data
mysql/data/
logs/
backups/
nginx/cache/

# SSL certificates (sensitive)
certbot/conf/
certbot/www/
certbot/logs/
cloudflare-certs/*/
local-certs/*/

# Docker
*.log

# Private docs (promotion plans, notes)
docs/

# OS
.DS_Store
Thumbs.db
