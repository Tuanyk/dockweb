# Docker Web Server Configuration
# IMPORTANT: Change all passwords before deploying to production!

# --- PHP Configuration (auto-calculated by dockweb from site count) ---

# --- Database Configuration ---
DB_ROOT_PASSWORD=secret
# TODO: Change MySQL password to 32+ character random string

# --- Backup Configuration ---
RESTIC_PASSWORD=my_secure_backup_password_123
# TODO: Change Restic password to 32+ character random string

# Alert email for backup/monitoring failures (optional)
ALERT_EMAIL=

# Backup schedule (cron format) and retention policy
BACKUP_SCHEDULE="0 3 * * *"
BACKUP_KEEP_DAILY=7
BACKUP_KEEP_WEEKLY=4
BACKUP_KEEP_MONTHLY=6

# --- SSL/Certbot Configuration ---
CERTBOT_EMAIL=admin@kairoxbuild.com
# TODO: Change to your actual email address

# --- Glances Monitoring ---
GLANCES_USERNAME=admin
GLANCES_PASSWORD=changeme
# TODO: Change Glances password to strong password

# --- Resource Limits ---
MYSQL_INNODB_BUFFER_POOL_SIZE=512M
PHP_PM_MAX_CHILDREN=5
REDIS_MAXMEMORY=256mbBACKUP_ENABLED=false
